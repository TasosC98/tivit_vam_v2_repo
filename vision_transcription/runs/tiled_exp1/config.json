{
  "profile": "auto",
  "profiles": {
    "dit": {
      "hostname": "vdcloud",
      "overrides": {
        "data.root": "/home/mkoziri/datasets/PianoVAM_v1.0",
        "train.device": "cpu"
      }
    },
    "dib": {
      "hostname": "gondor",
      "overrides": {
        "data.root": "/raid_storage/data_achatzigiannis/PianoVAM_v1.0",
        "train.device": "cuda"
      }
    }
  },
  "data": {
    "root": "/raid_storage/data_achatzigiannis/PianoVAM_v1.0",
    "metadata": "metadata_v2.json",
    "video_dir": "Video",
    "tsv_dir": "TSV",
    "midi_dir": "MIDI",
    "video_ext": ".mp4",
    "train_splits": [
      "train",
      "ext-train"
    ],
    "valid_splits": [
      "valid"
    ],
    "test_splits": [
      "test"
    ]
  },
  "keyboard": {
    "warp_width": 896,
    "warp_height": 112,
    "grayscale": false,
    "decode_height": 540,
    "read_chunk": 8
  },
  "labels": {
    "fps": 30.0,
    "pitch_min": 21,
    "pitch_max": 108,
    "offset_field": "key_offset",
    "onset_window_frames": 2,
    "min_note_frames": 1
  },
  "model": {
    "arch": "tiled",
    "encoder_channels": [
      32,
      64,
      128,
      192
    ],
    "feature_dim": 256,
    "gru_hidden": 256,
    "gru_layers": 2,
    "dropout": 0.2,
    "use_velocity": false,
    "tile_feature_dim": 64,
    "tile_gru_hidden": 128
  },
  "train": {
    "clip_len": 32,
    "clip_hop": 16,
    "batch_size": 2,
    "num_workers": 4,
    "max_open_readers": 3,
    "max_cached_targets": 16,
    "epochs": 30,
    "lr": 0.0006,
    "weight_decay": 0.0001,
    "amp": true,
    "grad_clip": 3.0,
    "onset_pos_weight": 8.0,
    "frame_pos_weight": 2.0,
    "velocity_loss_weight": 1.0,
    "log_every": 20,
    "eval_every_epochs": 1,
    "seed": 1234,
    "out_dir": "runs/tiled_exp1",
    "device": "cuda",
    "max_frames_per_record": 0
  },
  "decode": {
    "onset_threshold": 0.5,
    "frame_threshold": 0.5,
    "default_velocity": 80,
    "min_duration_s": 0.03
  },
  "infer": {
    "window_frames": 512,
    "window_hop": 448
  },
  "_active_profile": "dib"
}